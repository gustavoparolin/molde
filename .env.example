# ── Backend ────────────────────────────────────────────────────────────────
PORT=3000

# Comma-separated list of allowed CORS origins (frontend URLs). No trailing slash.
FRONTEND_ORIGINS=http://localhost:5173,https://molde-app.parolin.net

# Postgres connection string. Local dev default below; production value comes from Coolify.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/molde-app

# JWT — signs/verifies session tokens (REQUIRED in prod, use a DIFFERENT value than dev).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me

# Google OAuth (shared client for *.parolin.net). In DEV you can sign in via the mock form.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Optional: Claude AI (opt-in) ─────────────────────────────────────────────
# Used when the app extracts structured data from text/images. console.anthropic.com
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Optional: S3-compatible object storage / Cloudflare R2 (opt-in) ──────────
# Enable only if the app uploads files (photos, documents).
# S3_ENDPOINT=https://YOUR_CLOUDFLARE_ACCOUNT_ID.r2.cloudflarestorage.com
# S3_BUCKET=molde-app-assets
# S3_ACCESS_KEY=replace-me
# S3_SECRET_KEY=replace-me
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=true

# ── Frontend (build-time — set in Cloudflare Pages for production) ───────────
VITE_API_BASE_URL=http://localhost:3000

{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import=tsx src/api/server.ts",
    "start": "npm run db:migrate && node --import=tsx src/api/server.ts",
    "build": "echo 'No compile step: runtime TS execution via tsx'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^10.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "fastify": "^5.0.0",
    "pg": "^8.22.0",
    "tsx": "^4.20.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  }
}
